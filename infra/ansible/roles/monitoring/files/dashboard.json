        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\",cluster=\"aws\"})",
          "legendFormat": "AWS Ready Nodes",
          "refId": "B"
