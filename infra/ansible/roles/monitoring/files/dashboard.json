      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\",cluster=\"gcp\"})",
          "legendFormat": "GCP Ready Nodes",
          "refId": "A"
