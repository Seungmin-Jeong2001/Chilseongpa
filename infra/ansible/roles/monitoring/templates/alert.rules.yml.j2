groups:

  # [1. Node Resource Rules]
  - name: node-resource.rules
    rules:
      - alert: NodeCpuUsageHigh
        expr: 1 - avg by (cluster, instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) > 0.70
        for: 5m
        labels:
          severity: warning
          category: resource
          root_hint: "cpu_pressure"
        annotations:
          summary: "{% raw %}Node CPU 사용률 높음 ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}CPU 사용률 {{ $value | humanizePercentage }} - 70% 초과{% endraw %}"

      - alert: NodeCpuUsageCritical
        expr: 1 - avg by (cluster, instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) > 0.85
        for: 3m
        labels:
          severity: critical
          category: resource
          root_hint: "cpu_pressure"
        annotations:
          summary: "{% raw %}Node CPU 사용률 위험 ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}CPU 사용률 {{ $value | humanizePercentage }} - 85% 초과{% endraw %}"

      - alert: NodeMemoryUsageHigh
        expr: 1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.70
        for: 5m
        labels:
          severity: warning
          category: resource
          root_hint: "memory_pressure"
        annotations:
          summary: "{% raw %}Node Memory 사용률 높음 ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}Memory 사용률 {{ $value | humanizePercentage }} - 70% 초과{% endraw %}"

      - alert: NodeMemoryUsageCritical
        expr: 1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.85
        for: 3m
        labels:
          severity: critical
          category: resource
          root_hint: "memory_pressure"
        annotations:
          summary: "{% raw %}Node Memory 사용률 위험 ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}Memory 사용률 {{ $value | humanizePercentage }} - 85% 초과{% endraw %}"

      - alert: DiskSpaceLow
        expr: (node_filesystem_avail_bytes / node_filesystem_size_bytes) < 0.15
        for: 5m
        labels:
          severity: warning
          category: resource
          root_hint: "disk_pressure"
        annotations:
          summary: "{% raw %}Disk 여유 공간 부족 ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}Disk 여유 공간 {{ $value | humanizePercentage }} - 15% 미만{% endraw %}"

  # [2. Pod / Container Rules]
  - name: pod-container.rules
    rules:
      - alert: PodFailedWarning
        expr: count by (cluster, namespace) (kube_pod_status_phase{phase="Failed"}) >= 1
        for: 5m
        labels:
          severity: warning
          category: application
          root_hint: "pod_failed"
        annotations:
          summary: "{% raw %}Failed Pod 감지 ({{ $labels.cluster }} / {{ $labels.namespace }}){% endraw %}"
          description: "{% raw %}Failed Pod {{ $value }}개 발견{% endraw %}"

      - alert: PodFailedCritical
        expr: count by (cluster, namespace) (kube_pod_status_phase{phase="Failed"}) >= 3
        for: 5m
        labels:
          severity: critical
          category: application
          root_hint: "pod_failed"
        annotations:
          summary: "{% raw %}Failed Pod 다수 발생 ({{ $labels.cluster }} / {{ $labels.namespace }}){% endraw %}"
          description: "{% raw %}Failed Pod {{ $value }}개 - 서비스 영향 가능{% endraw %}"

      - alert: PodPendingWarning
        expr: count by (cluster, namespace) (kube_pod_status_phase{phase="Pending"}) >= 1
        for: 5m
        labels:
          severity: warning
          category: application
          root_hint: "pod_pending"
        annotations:
          summary: "{% raw %}Pending Pod 감지 ({{ $labels.cluster }} / {{ $labels.namespace }}){% endraw %}"
          description: "{% raw %}Pending Pod {{ $value }}개 - 스케줄링 지연{% endraw %}"

      - alert: PodPendingCritical
        expr: count by (cluster, namespace) (kube_pod_status_phase{phase="Pending"}) >= 3
        for: 5m
        labels:
          severity: critical
          category: application
          root_hint: "pod_pending"
        annotations:
          summary: "{% raw %}Pending Pod 다수 ({{ $labels.cluster }} / {{ $labels.namespace }}){% endraw %}"
          description: "{% raw %}Pending Pod {{ $value }}개 - 리소스 부족 의심{% endraw %}"

      - alert: ContainerRestartWarning
        expr: increase(kube_pod_container_status_restarts_total[5m]) >= 1
        for: 0m
        labels:
          severity: warning
          category: application
          root_hint: "container_restart"
        annotations:
          summary: "{% raw %}Container 재시작 감지 ({{ $labels.cluster }} / {{ $labels.pod }}){% endraw %}"
          description: "{% raw %}최근 5분간 {{ $value }}회 재시작{% endraw %}"

      - alert: ContainerRestartCritical
        expr: increase(kube_pod_container_status_restarts_total[5m]) >= 5
        for: 0m
        labels:
          severity: critical
          category: application
          root_hint: "container_restart"
        annotations:
          summary: "{% raw %}Container 반복 재시작 위험 ({{ $labels.cluster }} / {{ $labels.pod }}){% endraw %}"
          description: "{% raw %}최근 5분간 {{ $value }}회 재시작 - CrashLoopBackOff 가능성{% endraw %}"

      - alert: CriticalSystemPodDown
        expr: kube_pod_container_status_ready{namespace="kube-system", pod=~"coredns.*|cloudflared.*|traefik.*|local-path-provisioner.*"} == 0
        for: 2m
        labels:
          severity: critical
          category: infra
          root_hint: "system_pod_down"
        annotations:
          summary: "{% raw %}핵심 시스템 파드 장애 ({{ $labels.cluster }} / {{ $labels.pod }}){% endraw %}"
          description: "{% raw %}필수 컴포넌트 {{ $labels.pod }}가 정상 작동하지 않습니다.{% endraw %}"

  # [3. Cluster & Target Rules]
  - name: cluster.rules
    rules:
      - alert: NodeNotReady
        expr: kube_node_status_condition{condition="Ready", status="true"} == 0
        for: 3m
        labels:
          severity: critical
          category: infra
          root_hint: "instance_unreachable"
        annotations:
          summary: "{% raw %}Node NotReady ({{ $labels.cluster }} / {{ $labels.node }}){% endraw %}"
          description: "{% raw %}{{ $labels.node }} 노드가 NotReady 상태입니다.{% endraw %}"

      - alert: PrometheusTargetDown
        expr: up == 0
        for: 3m
        labels:
          severity: critical
          category: infra
          root_hint: "instance_unreachable"
        annotations:
          summary: "{% raw %}Prometheus Target Down ({{ $labels.cluster }} / {{ $labels.instance }}){% endraw %}"
          description: "{% raw %}{{ $labels.job }} 수집 실패 - 네트워크 확인 필요{% endraw %}"

  # [4. Infra Security Rules]
  - name: infra-security.rules
    rules:
      - alert: SSLCertExpiringSoon
        expr: (probe_ssl_earliest_cert_expiry - time()) / 3600 / 24 < 15
        for: 1h
        labels:
          severity: warning
          category: infra
          root_hint: "ssl_expiry"
        annotations:
          summary: "{% raw %}SSL 인증서 만료 임박 ({{ $labels.instance }}){% endraw %}"
          description: "{% raw %}인증서 만료가 {{ $value | humanizeDuration }} 남았습니다.{% endraw %}"

  # [5. Backend HTTP Rules]
  - name: backend-http.rules
    rules:
      - alert: BackendHttp5xxErrorRateWarning
        expr: sum by (cluster) (rate(backend_http_requests_total{status_code=~"5.."}[5m])) / sum by (cluster) (rate(backend_http_requests_total[5m])) > 0.01
        for: 3m
        labels:
          severity: warning
          category: application
          root_hint: "http_error"
        annotations:
          summary: "{% raw %}backend 5xx 에러율 높음 ({{ $labels.cluster }}){% endraw %}"
          description: "{% raw %}5xx 에러율 {{ $value | humanizePercentage }} 초과{% endraw %}"

      - alert: BackendHttp5xxErrorRateCritical
        expr: sum by (cluster) (rate(backend_http_requests_total{status_code=~"5.."}[5m])) / sum by (cluster) (rate(backend_http_requests_total[5m])) > 0.05
        for: 3m
        labels:
          severity: critical
          category: application
          root_hint: "http_error"
        annotations:
          summary: "{% raw %}backend 5xx 에러율 위험 ({{ $labels.cluster }}){% endraw %}"
          description: "{% raw %}5xx 에러율 {{ $value | humanizePercentage }} 초과{% endraw %}"

      - alert: BackendHttp4xxErrorRateWarning
        expr: sum by (cluster) (rate(backend_http_requests_total{status_code=~"4.."}[5m])) / sum by (cluster) (rate(backend_http_requests_total[5m])) > 0.05
        for: 3m
        labels:
          severity: warning
          category: application
          root_hint: "http_error"
        annotations:
          summary: "{% raw %}backend 4xx 에러율 높음 ({{ $labels.cluster }}){% endraw %}"
          description: "{% raw %}4xx 에러율 {{ $value | humanizePercentage }} 초과{% endraw %}"

      - alert: BackendHttp4xxErrorRateCritical
        expr: sum by (cluster) (rate(backend_http_requests_total{status_code=~"4.."}[5m])) / sum by (cluster) (rate(backend_http_requests_total[5m])) > 0.10
        for: 3m
        labels:
          severity: critical
          category: application
          root_hint: "http_error"
        annotations:
          summary: "{% raw %}backend 4xx 에러율 위험 ({{ $labels.cluster }}){% endraw %}"
          description: "{% raw %}4xx 에러율 {{ $value | humanizePercentage }} 초과{% endraw %}"