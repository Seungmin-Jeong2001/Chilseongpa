global:
  scrape_interval: 15s
  scrape_timeout: 10s
  evaluation_interval: 15s
  external_labels:
    monitor: 'gcp-prometheus'
    environment: 'prod'

rule_files:
  - "/etc/prometheus/alert.rules.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

scrape_configs:

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # 💡 GCP Cloud SQL 메트릭 수집
  # GCP Monitoring API → stackdriver-exporter → Prometheus
  - job_name: 'gcp-cloudsql'
    static_configs:
      - targets: ['stackdriver-exporter:9255']
        labels:
          cluster: 'gcp'
          service: 'cloudsql'
          environment: 'prod'

  # 💡 GCP Node Exporter - CPU/Memory (GCP 내부 직접 통신)
  - job_name: 'gcp-node-exporter'
    static_configs:
      - targets: ['{{ gcp_internal_ip }}:9100']
        labels:
          cluster: 'gcp'
          environment: 'prod'

  # 💡 GCP App 메트릭 - HTTP 요청수/응답시간 (GCP 내부 직접 통신)
  - job_name: 'gcp-app-metrics'
    static_configs:
      - targets: ['{{ gcp_internal_ip }}:30800']
        labels:
          cluster: 'gcp'
          service: 'backend'
          environment: 'prod'
    metric_relabel_configs:
      - source_labels: [__name__]
        regex: 'http_requests_total'
        target_label: __name__
        replacement: 'backend_http_requests_total'
      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_sum'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_sum'
      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_bucket'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_bucket'
      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_count'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_total'

  # 💡 GCP kube-state-metrics - Pod/Container 상태 (GCP 내부 직접 통신)
  - job_name: 'gcp-kube-state-metrics'
    static_configs:
      - targets: ['{{ gcp_internal_ip }}:30080']
        labels:
          cluster: 'gcp'
          environment: 'prod'

  # 💡 AWS App /metrics - CF Access 헤더로 HTTPS scrape
  # 모니터링이 GCP로 이전되면서 AWS VPC 직접 접근 불가 → CF Tunnel 경유
  - job_name: 'aws-app-metrics'
    scheme: https
    metrics_path: '/metrics'
    tls_config:
      insecure_skip_verify: true
    http_headers:
      CF-Access-Client-Id:
        values: ["{{ cf_client_id }}"]
      CF-Access-Client-Secret:
        values: ["{{ cf_client_secret }}"]
    static_configs:
      - targets: ['aws-app.bucheongoyangijanggun.com']
        labels:
          cluster: 'aws'
          service: 'backend'
          environment: 'prod'
    metric_relabel_configs:
      - source_labels: [__name__]
        regex: 'http_requests_total'
        target_label: __name__
        replacement: 'backend_http_requests_total'

      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_sum'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_sum'

      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_bucket'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_bucket'

      - source_labels: [__name__]
        regex: 'http_request_duration_seconds_count'
        target_label: __name__
        replacement: 'backend_http_request_duration_seconds_total'

  # 💡 AWS Node Exporter - CF Access 헤더로 HTTPS scrape
  - job_name: 'aws-node-exporter'
    scheme: https
    metrics_path: '/metrics'
    tls_config:
      insecure_skip_verify: true
    http_headers:
      CF-Access-Client-Id:
        values: ["{{ cf_client_id }}"]
      CF-Access-Client-Secret:
        values: ["{{ cf_client_secret }}"]
    static_configs:
      - targets: ['aws-node.bucheongoyangijanggun.com']
        labels:
          cluster: 'aws'
          environment: 'prod'

  # [추가] AWS kube-state-metrics - CF Access 헤더로 HTTPS scrape
  - job_name: 'aws-kube-state-metrics'
    scheme: https
    metrics_path: '/metrics'
    tls_config:
      insecure_skip_verify: true
    http_headers:
      CF-Access-Client-Id:
        values: ["{{ cf_client_id }}"]
      CF-Access-Client-Secret:
        values: ["{{ cf_client_secret }}"]
    static_configs:
      - targets: ['aws-ksm.bucheongoyangijanggun.com']
        labels:
          cluster: 'aws'
          environment: 'prod'