global:
  scrape_interval: 15s            # 기본 수집 주기
  scrape_timeout: 10s             # 수집 타임아웃

rule_files:
  - /etc/prometheus/alert.rules.yml   # Alert Rule 파일 로드

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093   # Docker 네트워크 내부 Alertmanager 주소

scrape_configs:
  - job_name: 'kubernetes'
    scheme: https
    metrics_path: /metrics

    headers:
      CF-Access-Client-Id: "{{ cf_client_id }}"         # Cloudflare Access 인증 헤더
      CF-Access-Client-Secret: "{{ cf_client_secret }}"

    static_configs:
      - targets:
          - "app-metrics.example.com"   # 애플리케이션 메트릭 엔드포인트
          - "node-metrics.example.com"  # 노드 메트릭 엔드포인트

    tls_config:
      insecure_skip_verify: true        # Tunnel/TLS 환경 고려